# vim: set ft=gitconfig :
# -*- mode: gitconfig -*-

[include]
  path = ~/.config/git/private.gitconfig

# More involved commands live in ~/.local/bin/git-*
[alias]
  who = var GIT_COMMITTER_IDENT
  branch = branch --sort=-committerdate
  nvm="! git reset --soft HEAD~1"
  append="! git add . && git commit --amend"
  locals = "! git branch --format '%(refname:short) %(upstream:short)' | awk '{if (!$2) print $1;}'"

[pull]
	rebase = true
[merge]
	conflictstyle = diff3
[rebase]
	autostash = true
	updateRefs = true
[push]
	autoSetupRemote = true
[init]
	defaultBranch = main
[rerere]
	enabled = true
[help]
	autocorrect = prompt
[diff]
	algorithm = histogram
